{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "محصول"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "description": {
      "type": "blocks"
    },
    "price": {
      "type": "decimal"
    },
    "display_price": {
      "type": "decimal",
      "default": 0
    },
    "sale_price": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "isActive": {
      "type": "boolean"
    },
    "brand": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::brand.brand"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "product"
    },
    "attributes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::attribute.attribute",
      "mappedBy": "product"
    },
    "attribute_values": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::attribute-value.attribute-value",
      "mappedBy": "product"
    },
    "is_featured": {
      "type": "boolean"
    },
    "is_flash_sale": {
      "type": "boolean"
    },
    "is_new_arrival": {
      "type": "boolean"
    },
    "is_best_seller": {
      "type": "boolean"
    },
    "is_popular": {
      "type": "boolean"
    },
    "is_top_seller": {
      "type": "boolean"
    },
    "is_on_selling": {
      "type": "boolean"
    }
  }
}
