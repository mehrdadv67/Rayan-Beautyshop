{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "سفارش"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "totalPrice": {
      "type": "decimal"
    },
    "statue": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "shipped",
        "done",
        "cancelled"
      ]
    },
    "order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
